```
#!/usr/bin/env bash
set -euo pipefail

SETTINGS="$HOME/Library/Application Support/Hypnograph/hypnograph-settings.json"

# Default paths for uploads sync
REMOTE_HOST="zissoudown@aero.usbx.me"
REMOTE_PATH="~/.apps/nextcloud/lorenjohnson@gmail.com/files/sharedwithme/"
DEFAULT_LOCAL_UPLOADS="$HOME/Movies/Hypnograph-Incoming"

usage() {
  echo "Usage:" >&2
  echo "  hypnograph add-source <path> [<path>...]" >&2
  echo "  hypnograph clear-sources" >&2
  echo "  hypnograph uploads sync" >&2
  exit 1
}

if [ "$#" -lt 1 ]; then
  usage
fi

cmd="$1"; shift

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required but not installed." >&2
  exit 1
fi

if [ ! -f "$SETTINGS" ]; then
  echo "Error: settings file not found at: $SETTINGS" >&2
  exit 1
fi

tmp="${SETTINGS}.tmp"

case "$cmd" in

  add-source)
    if [ "$#" -lt 1 ]; then
      usage
    fi

    for full in "$@"; do
      # Normalize to absolute path
      if [[ "$full" != /* ]]; then
        full="$(cd "$(dirname "$full")" && pwd)/$(basename "$full")"
      fi

      # Collapse $HOME to ~ for settings readability
      short="${full/#$HOME/~}"

      jq --arg p "$short" '
        .sources = (
          (.sources // []) + [$p]
          | unique
        )
      ' "$SETTINGS" > "$tmp"
      mv "$tmp" "$SETTINGS"
    done
    ;;

  clear-sources)
    if [ "$#" -ne 0 ]; then
      usage
    fi

    # Backup current settings with timestamp
    timestamp="$(date +%Y%m%d-%H%M%S)"
    backup="${SETTINGS}.${timestamp}.bak"
    cp -p "$SETTINGS" "$backup"
    echo "Backed up settings to: $backup"

    jq '
      .sources = []
    ' "$SETTINGS" > "$tmp"

    mv "$tmp" "$SETTINGS"
    echo "Cleared sources in settings."
    ;;

  uploads)
    if [ "$#" -lt 1 ]; then
      usage
    fi
    subcmd="$1"; shift

    case "$subcmd" in

      sync)
        if ! command -v rsync >/dev/null 2>&1; then
          echo "Error: rsync is required but not installed." >&2
          exit 1
        fi

        # Allow custom folder via settings key "uploadIngestFolder"
        local_uploads="$(jq -r '.uploadIngestFolder // empty' "$SETTINGS")"
        if [ -z "$local_uploads" ]; then
          local_uploads="$DEFAULT_LOCAL_UPLOADS"
        fi

        # Expand leading ~ manually
        case "$local_uploads" in
          "~"*)
            local_uploads="${HOME}${local_uploads#\~}"
            ;;
        esac

        mkdir -p "$local_uploads"

        echo "Syncing uploads from ${REMOTE_HOST}:${REMOTE_PATH}"
        echo "  → $local_uploads"

        rsync -avz --ignore-existing \
          "${REMOTE_HOST}:${REMOTE_PATH}" \
          "$local_uploads/"

        echo "Uploads sync complete."
        ;;

      *)
        usage
        ;;
    esac
    ;;

  *)
    usage
    ;;

esac
```
